<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <solid android:color="@color/white" />
        </shape>
    </item>
    <!-- We simulate 14 hour lines (8:00 to 22:00) with a repeating pattern or manual lines -->
    <!-- For simplicity, let's just use a stroke for the right border and then programmatically add lines if needed,
         or just use a simple background. In JS they use 14 div children.
         In Android we can use a custom view or just a tiled background. -->
    <item>
        <shape>
            <stroke android:width="1dp" android:color="#eeeeee" />
        </shape>
    </item>
</layer-list>