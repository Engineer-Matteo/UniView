<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    tools:context=".MainActivity">

    <!-- Header -->
    <TextView
        android:id="@+id/tvHeader"
        style="@style/MainHeaderStyle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/header_homepage"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/vHeaderDivider"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:background="@color/main_orange_stable"
        app:layout_constraintTop_toBottomOf="@id/tvHeader" />

    <ScrollView
        android:id="@+id/scrollView2"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/llFooter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/vHeaderDivider">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Next Event Banner -->
            <LinearLayout
                android:id="@+id/llNextEventContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_banner"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvNextEventLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_next_exam"
                    android:textColor="@color/main_orange"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvNextEventBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/next_event_loading"
                    android:textColor="@color/black" />
            </LinearLayout>

            <!-- Menu Items -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSchedule"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_schedule"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_schedule_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExams"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_exams"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_assignment_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnResults"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_results"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_assessment_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCourses"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_courses"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/outline_book_2_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSync"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_sync"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/baseline_cached_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/white"
                android:gravity="center_vertical|start"
                android:paddingStart="24dp"
                android:text="@string/menu_settings"
                android:textAllCaps="false"
                android:textColor="@color/main_blue"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:icon="@drawable/outline_admin_panel_settings_24"
                app:iconPadding="16dp"
                app:iconSize="24dp"
                app:iconTint="@color/main_blue"
                app:strokeColor="@color/main_blue"
                app:strokeWidth="2dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Footer Navigation -->
    <LinearLayout
        android:id="@+id/llFooter"
        style="@style/MainFooterStyle"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navHome"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:icon="@drawable/baseline_home_24"
            app:iconTint="@color/white_stable"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navSchedule"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:icon="@drawable/baseline_schedule_24"
            app:iconTint="@color/white_stable"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navExams"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:icon="@drawable/baseline_assignment_24"
            app:iconTint="@color/white_stable"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navResults"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:icon="@drawable/baseline_assessment_24"
            app:iconTint="@color/white_stable"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/navCourses"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            app:icon="@drawable/outline_book_2_24"
            app:iconTint="@color/white_stable"
            app:iconSize="28dp"
            app:iconGravity="textStart"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>